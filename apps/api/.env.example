# Development settings — DO NOT commit your real .env with secrets.
# Copy this file to .env and fill in your configuration.

PORT=4000

# MongoDB Connection
# For local MongoDB: mongodb://127.0.0.1:27017/bigbull
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# NOTE: The app's validateEnv checks for MONGODB_URI — use that variable name, not MONGO_URI
MONGO_URI=mongodb://127.0.0.1:27017/bigbull

# JWT Secrets (change these to secure random strings in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# JWT Expiration Times
JWT_ACCESS_EXPIRES=30s
JWT_REFRESH_EXPIRES=2h

# Google AI Studio — https://aistudio.google.com/apikey
GEMENI_API_KEY=your_gemini_api_key_here

# (Alpha Vantage removed) Market search and quotes are served from the
# internal Asset catalog and Redis price cache. No Alpha Vantage key is required.

# Redis (Upstash or local) — required for market price caching and BullMQ
# Upstash: rediss://<username>:<password>@<host>:<port>
# Local:   redis://localhost:6379
REDIS_URL=redis://localhost:6379

# JWT Refresh Secret — must be different from JWT_SECRET
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production

# ⚠️  Note: validateEnv() checks MONGODB_URI (not MONGO_URI).
# Add this alias or rename the existing MONGO_URI to MONGODB_URI.
MONGODB_URI=mongodb://127.0.0.1:27017/bigbull
