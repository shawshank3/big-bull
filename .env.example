# Root .env.example — merged from apps/ui and apps/api
# Copy this file to .env and fill in real values. DO NOT commit your .env file.

# ── apps/ui ────────────────────────────────────────────────────────────────────
# Base URL used by the frontend to reach the API (only used in production builds;
# in development the Vite proxy forwards /api requests to localhost:4000)
VITE_API_URL=http://localhost:4000/api

# Display name of the application
VITE_APP_NAME=BigBull

# ── apps/api ────────────────────────────────────────────────────────────────────
# Port the Express API server listens on
PORT=4000

# Runtime environment — use "production" on Render
NODE_ENV=development

# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/bigbull
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/bigbull

# JWT signing secret — use a long, random string in production
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# JWT access token lifetime (e.g. 15m, 1h, 7d)
JWT_ACCESS_EXPIRES=7d

# JWT refresh token lifetime (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES=30d

# Google AI Studio API key — https://aistudio.google.com/apikey
GEMENI_API_KEY=your_gemini_api_key_here

# (Alpha Vantage removed) Market search and quotes are served from the
# internal Asset catalog and Redis price cache. No Alpha Vantage key is required.
